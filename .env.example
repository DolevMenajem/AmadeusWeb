# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Local example: postgresql://postgres:password@localhost:5432/amadeus
# Supabase / Railway / Neon: copy the connection string from your dashboard.
DATABASE_URL=postgresql://user:password@localhost:5432/amadeus

# ── Gemini AI (required for Evaluate & Feedback / AI Lecturer) ───────────────
# Get a free key at https://aistudio.google.com/apikey
# The free tier is sufficient for development use.
GEMINI_API_KEY=your_gemini_api_key_here

# ── API server port (optional — defaults to 8080) ────────────────────────────
PORT=8080
